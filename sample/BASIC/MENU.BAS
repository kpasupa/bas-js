10 CLS: COLOR 7,0
20 LOCATE 1,29: COLOR 0,7: PRINT " BASIC: Core Language ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,5: PRINT "1.  Commands"
50 LOCATE 5,5: PRINT "2.  Statements"
60 LOCATE 6,5: PRINT "3.  Functions"
70 LOCATE 7,5: PRINT "4.  Operators"
80 LOCATE 9,5: PRINT "0.  Back"
90 LOCATE 10,1: PRINT STRING$(80,45)
100 LOCATE 12,5: COLOR 0,7: PRINT " Choose (0-4): ": COLOR 7,0
110 LOCATE 12,21: INPUT "",N
120 IF N=1 THEN CHAIN "BASIC/COMMAND/MENU"
130 IF N=2 THEN CHAIN "BASIC/STATEMENT/MENU"
140 IF N=3 THEN CHAIN "BASIC/FUNCTION/MENU"
150 IF N=4 THEN CHAIN "BASIC/OPERATOR/MENU"
160 IF N=0 THEN CHAIN "INTERPRETER"
170 GOTO 10
