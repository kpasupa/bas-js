10 CLS: COLOR 7,0
20 LOCATE 1,26: COLOR 0,7: PRINT " GW-BASIC: Screen Modes ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,5: PRINT "1  SCREEN 0   80 columns, 16-colour text  (this screen)"
50 LOCATE 5,5: PRINT "2  SCREEN 1   40 columns, 4-colour CGA graphics"
60 LOCATE 6,5: PRINT "3  SCREEN 2   80 columns, 2-colour graphics  (640x200)"
70 LOCATE 8,5: PRINT "0  Back"
80 LOCATE 9,1: PRINT STRING$(80,45)
90 LOCATE 11,5: COLOR 0,7: PRINT " Choose (0-3): ": COLOR 7,0
100 LOCATE 11,21: INPUT "",N
110 IF N=1 THEN CHAIN "GWBASIC/SCREEN/SCR0"
120 IF N=2 THEN CHAIN "GWBASIC/SCREEN/SCR1"
130 IF N=3 THEN CHAIN "GWBASIC/SCREEN/SCR2"
140 IF N=0 THEN CHAIN "GWBASIC/MENU"
150 GOTO 10
