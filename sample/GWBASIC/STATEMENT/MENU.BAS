10 CLS: COLOR 7,0
20 LOCATE 1,28: COLOR 0,7: PRINT " GW-BASIC: Statements ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,3: PRINT "   1 CLS/COLOR/LOCATE/BEEP    8 Random files (FIELD/PUT/GET)"
50 LOCATE 5,3: PRINT "   2 PRINT USING              9 Sequential files (WRITE#/INPUT#)"
60 LOCATE 6,3: PRINT "   3 LINE INPUT              10 Graphics (SCREEN/LINE/CIRCLE/PAINT)"
70 LOCATE 7,3: PRINT "   4 WRITE                  11 Sound (SOUND/PLAY)"
80 LOCATE 8,3: PRINT "   5 SWAP / ERASE            12 CHAIN / COMMON"
90 LOCATE 9,3: PRINT "   6 DEFINT / DEFSTR         13 ON KEY / ON TIMER (event traps)"
100 LOCATE 10,3: PRINT "   7 ON ERROR / RESUME"
110 LOCATE 12,3: COLOR 8,0: PRINT "  (WIDTH KEY VIEWPRINT = partial;  WAIT OUT CALL = skip)": COLOR 7,0
120 LOCATE 13,1: PRINT STRING$(80,45)
130 LOCATE 15,5: PRINT "0  Back"
140 LOCATE 16,1: PRINT STRING$(80,45)
150 LOCATE 18,5: COLOR 0,7: PRINT " Choose (0-13): ": COLOR 7,0
160 LOCATE 18,22: INPUT "",N
170 IF N=0 THEN CHAIN "GWBASIC/MENU"
180 ON N GOSUB 200,300,400,500,600,700,800,1000,1200,1400,1600,1800,2000
190 GOTO 10
200 CLS: PRINT "CLS  COLOR  LOCATE  BEEP": PRINT
210 COLOR 14,0: PRINT "  this line is bright yellow": COLOR 7,0
220 LOCATE 6,20: PRINT "<- LOCATE 6,20"
230 BEEP: LOCATE 9,1: PRINT "  (BEEP just sounded)": GOTO 9000
300 CLS: PRINT "PRINT USING": PRINT
310 PRINT USING "  ###,###.##"; 1234.5
320 PRINT USING "  ##/##/##"; 12; 31; 26: GOTO 9000
400 CLS: PRINT "LINE INPUT  (reads whole line, commas included)": PRINT
410 LINE INPUT "  Type anything: "; L$: PRINT "  Got: ["; L$; "]": GOTO 9000
500 CLS: PRINT "WRITE  (comma-delimited, strings quoted)": PRINT
510 PRINT "  "; : WRITE 1,"AB",3: GOTO 9000
600 CLS: PRINT "SWAP / ERASE": PRINT: A=1: B=2: PRINT "  before:"; A; B
610 SWAP A,B: PRINT "  after SWAP:"; A; B: GOTO 9000
700 CLS: PRINT "DEFINT / DEFSTR  (default variable types)": PRINT
710 DEFINT D: D=3.7: PRINT "  DEFINT D,  D=3.7  ->"; D: GOTO 9000
800 CLS: PRINT "ON ERROR / ERROR / RESUME": PRINT: ON ERROR GOTO 8800
810 ERROR 57: GOTO 9000
8800 PRINT "  Trapped!  ERR ="; ERR; "  ERL ="; ERL: RESUME 9000
1000 CLS: PRINT "Random file  OPEN / FIELD / LSET / PUT / GET": PRINT
1010 OPEN "ZZRND.DAT" AS #1 LEN=10: FIELD #1, 5 AS A$, 5 AS B$
1020 LSET A$="HI": RSET B$="YOU": PUT #1,1
1030 GET #1,1: PRINT "  read: ["; A$; "]["; B$; "]"
1040 CLOSE #1: KILL "ZZRND.DAT": GOTO 9000
1200 CLS: PRINT "Sequential file  OPEN / WRITE# / INPUT# / EOF": PRINT
1210 OPEN "ZZSEQ.DAT" FOR OUTPUT AS #1: WRITE #1,"SAM",30: CLOSE #1
1220 OPEN "ZZSEQ.DAT" FOR INPUT AS #1: INPUT #1,N$,A
1230 PRINT "  read back:"; N$; A, "EOF ="; EOF(1)
1240 CLOSE #1: KILL "ZZSEQ.DAT": GOTO 9000
1400 CLS: PRINT "Graphics  SCREEN / LINE / CIRCLE / PAINT / PALETTE": PRINT
1410 PRINT "  Loading graphics...": FOR D=1 TO 600: NEXT
1420 SCREEN 2: PALETTE 0,1: PALETTE 1,14: CLS
1430 LINE (80,10)-(560,80),1,BF
1440 CIRCLE (320,148),50,1: PAINT (320,148),1,1
1450 LOCATE 4,28: PRINT "Hello World";
1460 A$=INPUT$(1): PALETTE: SCREEN 0: RETURN
1600 CLS: PRINT "SOUND / PLAY": PRINT: PRINT "  Frequency sweep..."
1610 FOR F=300 TO 1500 STEP 200: SOUND F,2: NEXT
1620 PRINT "  Tune...": PLAY "T140 O4 L8 CDEFGAB O5 C": GOTO 9000
1800 CLS: PRINT "CHAIN / COMMON": PRINT
1810 PRINT "  CHAIN loads and runs another .BAS file."
1820 PRINT "  COMMON passes variables across the CHAIN boundary."
1830 PRINT "  This entire menu tree uses CHAIN to move between files.": GOTO 9000
2000 CLS: PRINT "ON KEY / ON TIMER  (event traps)": PRINT
2010 PRINT "  ON TIMER(1) fires a GOSUB every second."
2020 PRINT "  ON KEY(1) fires a GOSUB when F1 is pressed."
2030 PRINT "  Press F1 a few times; any other key to stop."
2040 TICK=0: FCT=0
2050 ON TIMER(1) GOSUB 2200: ON KEY(1) GOSUB 2300
2060 TIMER ON: KEY(1) ON
2070 K$=INKEY$: IF K$="" THEN 2070
2080 TIMER OFF: KEY(1) OFF
2090 LOCATE 14,1: PRINT "  Timer ticks:"; TICK, "F1 presses:"; FCT: GOTO 9000
2200 TICK=TICK+1: LOCATE 11,1: PRINT "  ...tick"; TICK: RETURN
2300 FCT=FCT+1: LOCATE 12,1: PRINT "  ...F1 #"; FCT: RETURN
9000 PRINT: PRINT "  Press any key...": A$=INPUT$(1): RETURN
