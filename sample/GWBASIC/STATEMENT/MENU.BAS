10 CLS:COLOR 7,0
20 PRINT "===== GW-BASIC : Statements ====="
30 PRINT
40 PRINT "  1 CLS/COLOR/LOCATE/BEEP   7 ON ERROR/ERROR"
50 PRINT "  2 PRINT USING            8 random files"
60 PRINT "  3 LINE INPUT             9 sequential files"
70 PRINT "  4 WRITE                 10 GRAPHICS (draw)"
80 PRINT "  5 SWAP/ERASE            11 SOUND/PLAY"
90 PRINT "  6 DEFINT/DEFSTR/...     12 CHAIN/COMMON (info)"
100 PRINT
110 PRINT "  (WIDTH KEY VIEWPRINT=PART; WAIT OUT CALL=SKIP;"
120 PRINT "   ON KEY/TIMER=TODO)"
130 PRINT "  0 Back"
140 INPUT "Choose";N
150 IF N=0 THEN CHAIN "GWBASIC/MENU"
160 ON N GOSUB 200,300,400,500,600,700,800,1000,1200,1400,1600,1800
170 GOTO 10
200 CLS:PRINT "CLS COLOR LOCATE BEEP":PRINT
210 COLOR 14,0:PRINT "  this line is bright yellow":COLOR 7,0
220 LOCATE 6,20:PRINT "<- LOCATE 6,20"
230 BEEP:LOCATE 9,1:PRINT "  (BEEP just sounded)":GOTO 9000
300 CLS:PRINT "PRINT USING":PRINT
310 PRINT USING "  ###,###.## ";1234.5
320 PRINT USING "  ##/##/## ";12;31;26:GOTO 9000
400 CLS:PRINT "LINE INPUT  (reads a whole line, commas incl.)":PRINT
410 LINE INPUT "  Type anything: ";L$:PRINT "  Got: [";L$;"]":GOTO 9000
500 CLS:PRINT "WRITE  (comma-delimited, strings quoted)":PRINT:PRINT "  ";:WRITE 1,"AB",3:GOTO 9000
600 CLS:PRINT "SWAP / ERASE":PRINT:A=1:B=2:PRINT "  before:";A;B
610 SWAP A,B:PRINT "  after SWAP:";A;B:GOTO 9000
700 CLS:PRINT "DEFINT / DEFSTR (default types)":PRINT
710 DEFINT D:D=3.7:PRINT "  DEFINT D, D=3.7 ->";D:GOTO 9000
800 CLS:PRINT "ON ERROR / ERROR / RESUME":PRINT:ON ERROR GOTO 8800
810 ERROR 57:GOTO 9000
8800 PRINT "  trapped! ERR=";ERR;" ERL=";ERL:RESUME 9000
1000 CLS:PRINT "Random file  OPEN/FIELD/LSET/PUT/GET":PRINT
1010 OPEN "ZZRND.DAT" AS #1 LEN=10:FIELD #1,5 AS A$,5 AS B$
1020 LSET A$="HI":RSET B$="YOU":PUT #1,1
1030 GET #1,1:PRINT "  read: [";A$;"][";B$;"]"
1040 CLOSE #1:KILL "ZZRND.DAT":GOTO 9000
1200 CLS:PRINT "Sequential file  OPEN/WRITE#/INPUT#/EOF":PRINT
1210 OPEN "ZZSEQ.DAT" FOR OUTPUT AS #1:WRITE #1,"SAM",30:CLOSE #1
1220 OPEN "ZZSEQ.DAT" FOR INPUT AS #1:INPUT #1,N$,A
1230 PRINT "  read back: ";N$;A;"  EOF=";EOF(1)
1240 CLOSE #1:KILL "ZZSEQ.DAT":GOTO 9000
1400 CLS:PRINT "GRAPHICS - drawing on SCREEN 1...":FOR D=1 TO 600:NEXT
1410 SCREEN 1:CLS
1420 LINE (10,10)-(150,80),2,B:LINE (170,10)-(300,80),1,BF
1430 CIRCLE (80,140),35,2:PAINT (80,140),1,2
1440 PSET (200,120):DRAW "C3 R60 D40 L60 U40"
1450 A$=INPUT$(1):SCREEN 0:RETURN
1600 CLS:PRINT "SOUND / PLAY":PRINT:PRINT "  sweep..."
1610 FOR F=300 TO 1500 STEP 200:SOUND F,2:NEXT
1620 PRINT "  tune...":PLAY "T140 O4 L8 CDEFGAB O5 C":GOTO 9000
1800 CLS:PRINT "CHAIN / COMMON":PRINT
1810 PRINT "  CHAIN loads+runs another .BAS (this menu uses it)."
1820 PRINT "  COMMON passes vars/arrays across a CHAIN.":GOTO 9000
9000 PRINT:PRINT "Press a key...":A$=INPUT$(1):RETURN
