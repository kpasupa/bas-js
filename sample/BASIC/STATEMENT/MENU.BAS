10 CLS: COLOR 7,0
20 LOCATE 1,30: COLOR 0,7: PRINT " BASIC: Statements ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,3: PRINT "  1 LET / assign      7 GOSUB / RETURN"
50 LOCATE 5,3: PRINT "  2 PRINT  (; ,)      8 ON n GOTO / GOSUB"
60 LOCATE 6,3: PRINT "  3 INPUT             9 DIM / arrays"
70 LOCATE 7,3: PRINT "  4 IF / THEN / ELSE 10 DATA / READ / RESTORE"
80 LOCATE 8,3: PRINT "  5 FOR / NEXT       11 DEF FN"
90 LOCATE 9,3: PRINT "  6 WHILE / WEND     12 RANDOMIZE / CLEAR"
100 LOCATE 11,3: COLOR 8,0: PRINT "  (END STOP REM OPTION BASE also work; POKE = skip)": COLOR 7,0
110 LOCATE 12,1: PRINT STRING$(80,45)
120 LOCATE 14,5: PRINT "0  Back"
130 LOCATE 15,1: PRINT STRING$(80,45)
140 LOCATE 17,5: COLOR 0,7: PRINT " Choose (0-12): ": COLOR 7,0
150 LOCATE 17,22: INPUT "",N
160 IF N=0 THEN CHAIN "BASIC/MENU"
170 ON N GOSUB 200,300,400,500,600,700,800,900,1000,1100,1200,1300
180 GOTO 10
200 CLS: PRINT "LET / assignment": PRINT: A=5: B$="HI": PRINT "  A ="; A, "B$ = "; B$: GOTO 9000
300 CLS: PRINT "PRINT  ; packs tight,  , tabs to print zones": PRINT
310 PRINT "  1;2;3  ->"; 1; 2; 3: PRINT "  1,2,3  ->"; 1, 2, 3: GOTO 9000
400 CLS: PRINT "INPUT": PRINT: INPUT "  Type a number: ", X: PRINT "  You typed"; X: GOTO 9000
500 CLS: PRINT "IF / THEN / ELSE": PRINT
510 IF 3>2 THEN PRINT "  3 > 2  is TRUE" ELSE PRINT "  false"
520 GOTO 9000
600 CLS: PRINT "FOR / NEXT": PRINT: S=0
610 FOR I=1 TO 5: S=S+I: NEXT: PRINT "  sum 1..5 ="; S: GOTO 9000
700 CLS: PRINT "WHILE / WEND": PRINT: I=1: S=0
710 WHILE I<=5: S=S+I: I=I+1: WEND: PRINT "  sum 1..5 ="; S: GOTO 9000
800 CLS: PRINT "GOSUB / RETURN": PRINT: GOSUB 8500: PRINT "  back from sub": GOTO 9000
900 CLS: PRINT "ON n GOTO / GOSUB": PRINT
910 FOR K=1 TO 3: ON K GOSUB 8600,8610,8620: NEXT: GOTO 9000
1000 CLS: PRINT "DIM / arrays": PRINT: DIM A(5)
1010 FOR I=1 TO 5: A(I)=I*I: NEXT
1020 PRINT "  squares:"; A(1); A(2); A(3); A(4); A(5): GOTO 9000
1100 CLS: PRINT "DATA / READ / RESTORE": PRINT
1110 READ X,Y,Z: PRINT "  read:"; X; Y; Z
1120 RESTORE: READ W: PRINT "  after RESTORE, first ="; W
1130 DATA 11,22,33: GOTO 9000
1200 CLS: PRINT "DEF FN": PRINT: DEF FNSQ(X)=X*X
1210 PRINT "  FNSQ(9) ="; FNSQ(9): GOTO 9000
1300 CLS: PRINT "RANDOMIZE / CLEAR": PRINT: Q=99
1310 RANDOMIZE 7: PRINT "  seeded RND:"; RND
1320 CLEAR: PRINT "  after CLEAR, Q ="; Q; "  (reset to 0)": GOTO 9000
8500 PRINT "  in sub — returning": RETURN
8600 PRINT "  branch 1": RETURN
8610 PRINT "  branch 2": RETURN
8620 PRINT "  branch 3": RETURN
9000 PRINT: PRINT "  Press any key...": A$=INPUT$(1): RETURN
