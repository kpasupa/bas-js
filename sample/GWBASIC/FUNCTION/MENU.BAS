10 CLS: COLOR 7,0
20 LOCATE 1,29: COLOR 0,7: PRINT " GW-BASIC: Functions ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,3: PRINT "   1 INKEY$                  6 DATE$ / TIME$ / TIMER"
50 LOCATE 5,3: PRINT "   2 INPUT$(n)               7 ERR / ERL"
60 LOCATE 6,3: PRINT "   3 CVI / MKI$              8 POS / CSRLIN"
70 LOCATE 7,3: PRINT "   4 CVS/MKS$  CVD/MKD$      9 POINT / PMAP  (graphics)"
80 LOCATE 8,3: PRINT "   5 LOC / LOF / EOF         10 FRE  (dummy)"
90 LOCATE 10,3: COLOR 8,0: PRINT "  (VARPTR INP = skip;  SCREEN() = partial)": COLOR 7,0
100 LOCATE 11,1: PRINT STRING$(80,45)
110 LOCATE 13,5: PRINT "0  Back"
120 LOCATE 14,1: PRINT STRING$(80,45)
130 LOCATE 16,5: COLOR 0,7: PRINT " Choose (0-10): ": COLOR 7,0
140 LOCATE 16,22: INPUT "",N
150 IF N=0 THEN CHAIN "GWBASIC/MENU"
160 ON N GOSUB 200,300,400,500,600,700,800,900,1000,1100
170 GOTO 10
200 CLS: PRINT "INKEY$  (non-blocking key read)": PRINT: PRINT "  Press any key..."
210 K$=INKEY$: IF K$="" THEN 210
220 PRINT "  Got CHR$("; ASC(K$); ") = ["; K$; "]": GOTO 9000
300 CLS: PRINT "INPUT$(n)  (read exactly n keys, blocking)": PRINT
310 PRINT "  Type 3 keys: "; : A$=INPUT$(3): PRINT: PRINT "  Got ["; A$; "]": GOTO 9000
400 CLS: PRINT "CVI / MKI$  (16-bit integer <-> 2 bytes)": PRINT
410 PRINT "  CVI(MKI$(1234)) ="; CVI(MKI$(1234)): GOTO 9000
500 CLS: PRINT "CVS/MKS$  (single)   CVD/MKD$  (double)   MBF binary": PRINT
510 PRINT "  CVS(MKS$(3.14))  ="; CVS(MKS$(3.14))
520 PRINT "  CVD(MKD$(2.5))   ="; CVD(MKD$(2.5)): GOTO 9000
600 CLS: PRINT "LOC / LOF / EOF": PRINT
610 OPEN "ZZF.DAT" FOR OUTPUT AS #1: PRINT #1,"ABCDE";: CLOSE #1
620 OPEN "ZZF.DAT" FOR INPUT AS #1: PRINT "  LOF ="; LOF(1), "EOF ="; EOF(1)
630 CLOSE #1: KILL "ZZF.DAT": GOTO 9000
700 CLS: PRINT "DATE$  TIME$  TIMER": PRINT
710 PRINT "  DATE$ ="; DATE$: PRINT "  TIME$ ="; TIME$
720 PRINT "  TIMER ="; TIMER; "  (seconds since midnight)": GOTO 9000
800 CLS: PRINT "ERR / ERL": PRINT: ON ERROR GOTO 8800: ERROR 11: GOTO 9000
8800 PRINT "  ERR ="; ERR, "ERL ="; ERL: RESUME 9000
900 CLS: PRINT "POS / CSRLIN  (cursor column / row)": PRINT
910 LOCATE 8,15: PRINT "X"; : PRINT: PRINT "  After the X above:  POS ="; POS(0); "  CSRLIN was 8": GOTO 9000
1000 CLS: PRINT "POINT / PMAP  (on SCREEN 1...)": PRINT
1010 PRINT "  Loading graphics...": FOR D=1 TO 500: NEXT
1020 SCREEN 1: CLS: LINE (0,0)-(200,100),2: CIRCLE (100,150),40,3: PAINT (100,150),1,3
1030 C1=POINT(100,150): C2=POINT(2,2): SCREEN 0
1040 PRINT "  POINT at fill centre ="; C1; "  (1)"
1050 PRINT "  POINT at background  ="; C2; "  (0)": GOTO 9000
1100 CLS: PRINT "FRE  (dummy)": PRINT
1110 PRINT "  FRE(0) ="; FRE(0)
1120 PRINT "  Returns a faked constant — modern RAM is effectively unlimited.": GOTO 9000
9000 PRINT: PRINT "  Press any key...": A$=INPUT$(1): RETURN
