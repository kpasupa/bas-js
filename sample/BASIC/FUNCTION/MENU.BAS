10 CLS: COLOR 7,0
20 LOCATE 1,31: COLOR 0,7: PRINT " BASIC: Functions ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,3: PRINT "  1 ABS / SGN / INT / FIX    7 STR$ / CHR$ / ASC"
50 LOCATE 5,3: PRINT "  2 SQR                      8 LEFT$ / RIGHT$ / MID$"
60 LOCATE 6,3: PRINT "  3 SIN / COS / TAN / ATN    9 STRING$ / SPACE$"
70 LOCATE 7,3: PRINT "  4 LOG / EXP               10 INSTR"
80 LOCATE 8,3: PRINT "  5 RND                     11 HEX$ / OCT$"
90 LOCATE 9,3: PRINT "  6 LEN / VAL               12 CINT / CSNG / CDBL"
100 LOCATE 11,3: COLOR 8,0: PRINT "  (PEEK = skip, hardware)": COLOR 7,0
110 LOCATE 12,1: PRINT STRING$(80,45)
120 LOCATE 14,5: PRINT "0  Back"
130 LOCATE 15,1: PRINT STRING$(80,45)
140 LOCATE 17,5: COLOR 0,7: PRINT " Choose (0-12): ": COLOR 7,0
150 LOCATE 17,22: INPUT "",N
160 IF N=0 THEN CHAIN "BASIC/MENU"
170 ON N GOSUB 200,300,400,500,600,700,800,900,1000,1100,1200,1300
180 GOTO 10
200 CLS: PRINT "ABS  SGN  INT  FIX": PRINT
210 PRINT "  ABS(-5)  ="; ABS(-5), "SGN(-9)  ="; SGN(-9)
220 PRINT "  INT(3.7) ="; INT(3.7), "FIX(-3.7)="; FIX(-3.7): GOTO 9000
300 CLS: PRINT "SQR": PRINT: PRINT "  SQR(144) ="; SQR(144): GOTO 9000
400 CLS: PRINT "SIN  COS  TAN  ATN  (radians)": PRINT
410 PRINT "  SIN(0) ="; SIN(0), "COS(0) ="; COS(0)
420 PRINT "  ATN(1)*4 ="; ATN(1)*4, "(= pi)": GOTO 9000
500 CLS: PRINT "LOG  EXP": PRINT
510 PRINT "  LOG(2.718282) ="; LOG(2.718282), "EXP(1) ="; EXP(1): GOTO 9000
600 CLS: PRINT "RND  (seedable)": PRINT
610 RANDOMIZE 1: PRINT "  seed 1:"; RND; RND
620 PRINT "  RND(0) repeats last:"; RND(0): GOTO 9000
700 CLS: PRINT "LEN  VAL": PRINT
710 PRINT "  LEN(""HELLO"") ="; LEN("HELLO"), "VAL(""42.5"") ="; VAL("42.5"): GOTO 9000
800 CLS: PRINT "STR$  CHR$  ASC": PRINT
810 PRINT "  STR$(7)  = ["; STR$(7); "]   CHR$(65) ="; CHR$(65)
820 PRINT "  ASC(""A"") ="; ASC("A"): GOTO 9000
900 CLS: PRINT "LEFT$  RIGHT$  MID$": PRINT
910 PRINT "  LEFT$(""ABCDE"",2)    ="; LEFT$("ABCDE",2)
920 PRINT "  RIGHT$(""ABCDE"",2)   ="; RIGHT$("ABCDE",2)
930 PRINT "  MID$(""ABCDE"",2,3)   ="; MID$("ABCDE",2,3): GOTO 9000
1000 CLS: PRINT "STRING$  SPACE$": PRINT
1010 PRINT "  STRING$(5,""*"") ="; STRING$(5,"*")
1020 PRINT "  ["; SPACE$(5); "]  = SPACE$(5)": GOTO 9000
1100 CLS: PRINT "INSTR": PRINT
1110 PRINT "  INSTR(""HELLO"",""LL"")       ="; INSTR("HELLO","LL")
1120 PRINT "  INSTR(4,""ABCABC"",""B"")    ="; INSTR(4,"ABCABC","B"): GOTO 9000
1200 CLS: PRINT "HEX$  OCT$": PRINT
1210 PRINT "  HEX$(255) ="; HEX$(255), "OCT$(8) ="; OCT$(8)
1220 PRINT "  HEX$(-1)  ="; HEX$(-1): GOTO 9000
1300 CLS: PRINT "CINT  CSNG  CDBL": PRINT
1310 PRINT "  CINT(2.5) ="; CINT(2.5), "(ties round to even)  CINT(3.5) ="; CINT(3.5)
1320 PRINT "  CDBL(7)   ="; CDBL(7): GOTO 9000
9000 PRINT: PRINT "  Press any key...": A$=INPUT$(1): RETURN
