10 CLS
20 PRINT "===== GW-BASIC : Functions ====="
30 PRINT
40 PRINT "  1 INKEY$            6 DATE$/TIME$/TIMER"
50 PRINT "  2 INPUT$(n)         7 ERR/ERL"
60 PRINT "  3 CVI/MKI$          8 POS/CSRLIN"
70 PRINT "  4 CVS/MKS$ CVD/MKD$ 9 POINT/PMAP (gfx)"
80 PRINT "  5 LOC/LOF/EOF      10 FRE (DUMMY)"
90 PRINT
100 PRINT "  (VARPTR INP = SKIP; SCREEN() = PART)"
110 PRINT "  0 Back"
120 INPUT "Choose";N
130 IF N=0 THEN CHAIN "GWBASIC/MENU"
140 ON N GOSUB 200,300,400,500,600,700,800,900,1000,1100
150 GOTO 10
200 CLS:PRINT "INKEY$  (no-wait key read)":PRINT:PRINT "  Press any key..."
210 K$=INKEY$:IF K$="" THEN 210
220 PRINT "  got CHR$(";ASC(K$);") = [";K$;"]":GOTO 9000
300 CLS:PRINT "INPUT$(n)  (read n keys, blocking)":PRINT
310 PRINT "  Type 3 keys: ";:A$=INPUT$(3):PRINT:PRINT "  got [";A$;"]":GOTO 9000
400 CLS:PRINT "CVI / MKI$  (16-bit int <-> 2 bytes)":PRINT
410 PRINT "  CVI(MKI$(1234)) =";CVI(MKI$(1234)):GOTO 9000
500 CLS:PRINT "CVS/MKS$ (single)  CVD/MKD$ (double) - MBF":PRINT
510 PRINT "  CVS(MKS$(3.14)) =";CVS(MKS$(3.14))
520 PRINT "  CVD(MKD$(2.5))  =";CVD(MKD$(2.5)):GOTO 9000
600 CLS:PRINT "LOC / LOF / EOF":PRINT
610 OPEN "ZZF.DAT" FOR OUTPUT AS #1:PRINT #1,"ABCDE";:CLOSE #1
620 OPEN "ZZF.DAT" FOR INPUT AS #1:PRINT "  LOF =";LOF(1);"  EOF =";EOF(1)
630 CLOSE #1:KILL "ZZF.DAT":GOTO 9000
700 CLS:PRINT "DATE$ / TIME$ / TIMER":PRINT
710 PRINT "  DATE$ = ";DATE$:PRINT "  TIME$ = ";TIME$
720 PRINT "  TIMER =";TIMER;"(secs since midnight)":GOTO 9000
800 CLS:PRINT "ERR / ERL":PRINT:ON ERROR GOTO 8800:ERROR 11:GOTO 9000
8800 PRINT "  ERR =";ERR;"  ERL =";ERL:RESUME 9000
900 CLS:PRINT "POS / CSRLIN  (cursor column / row)":PRINT
910 LOCATE 8,15:PRINT "X";:PRINT:PRINT "  after the X: POS =";POS(0);" CSRLIN was 8":GOTO 9000
1000 CLS:PRINT "POINT / PMAP  (drawing on SCREEN 1...)":FOR D=1 TO 500:NEXT
1010 SCREEN 1:CLS:LINE (0,0)-(200,100),2:CIRCLE (100,150),40,3:PAINT (100,150),1,3
1020 C1=POINT(100,150):C2=POINT(2,2):SCREEN 0
1030 PRINT "  POINT centre of fill =";C1;" (1)"
1040 PRINT "  POINT background     =";C2;" (0)":GOTO 9000
1100 CLS:PRINT "FRE  (DUMMY)":PRINT
1110 PRINT "  FRE(0) =";FRE(0)
1120 PRINT "  (faked constant - modern RAM is effectively unlimited)":GOTO 9000
9000 PRINT:PRINT "Press a key...":A$=INPUT$(1):RETURN
