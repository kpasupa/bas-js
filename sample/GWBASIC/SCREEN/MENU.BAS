10 CLS: COLOR 7,0
20 LOCATE 1,26: COLOR 0,7: PRINT " GW-BASIC: Screen Modes ": COLOR 7,0
30 LOCATE 2,1: PRINT STRING$(80,45)
40 LOCATE 4,5: PRINT "0  SCREEN 0   80 columns, 16-colour text  (this screen)"
50 LOCATE 5,5: PRINT "1  SCREEN 1   40 columns, 4-colour CGA graphics"
60 LOCATE 6,5: PRINT "2  SCREEN 2   80 columns, 2-colour graphics  (640x200)"
70 LOCATE 8,5: PRINT "B  Back"
80 LOCATE 9,1: PRINT STRING$(80,45)
90 LOCATE 11,5: COLOR 0,7: PRINT " Choose (0-2, B): ": COLOR 7,0
100 LOCATE 11,23: INPUT "",A$
110 A$=UCASE$(LEFT$(A$+" ",1))
120 IF A$="0" THEN CHAIN "GWBASIC/SCREEN/SCR0"
130 IF A$="1" THEN CHAIN "GWBASIC/SCREEN/SCR1"
140 IF A$="2" THEN CHAIN "GWBASIC/SCREEN/SCR2"
150 IF A$="B" THEN CHAIN "GWBASIC/MENU"
160 GOTO 10
